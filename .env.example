# PostgreSQL
POSTGRES_USER=autopatch
POSTGRES_PASSWORD=autopatch_dev
POSTGRES_DB=autopatch
DATABASE_URL=postgresql+asyncpg://autopatch:autopatch_dev@localhost:5432/autopatch

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API Keys (comma-separated)
API_KEYS=dev-api-key-1,dev-api-key-2

# App
APP_NAME=Autopatch
DEBUG=true
LOG_LEVEL=INFO

# Greenbone GMP
GMP_HOST=gvmd
GMP_PORT=9390
GMP_USERNAME=admin
GMP_PASSWORD=admin

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Scanner webhook base URL
WEBHOOK_BASE_URL=http://api:8000

# NVD API (optional, for higher rate limits)
NVD_API_KEY=
