# PostgreSQL
POSTGRES_USER=autopatch
POSTGRES_PASSWORD=autopatch_dev
POSTGRES_DB=autopatch
DATABASE_URL=postgresql+asyncpg://autopatch:autopatch_dev@localhost:5432/autopatch

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# API Keys (comma-separated)
API_KEYS=dev-api-key-1,dev-api-key-2

# App
APP_NAME=Autopatch
DEBUG=true
LOG_LEVEL=INFO

# Greenbone GMP
GMP_HOST=gvmd
GMP_PORT=9390
GMP_USERNAME=admin
GMP_PASSWORD=admin

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Scanner webhook base URL
WEBHOOK_BASE_URL=http://api:8000

# NVD API (optional, for higher rate limits)
NVD_API_KEY=

# LLM (OpenAI-compatible endpoint — vLLM, Ollama, or cloud)
LLM_BASE_URL=http://vllm:8001/v1
LLM_MODEL=Qwen/Qwen3-30B-A3B

# HashiCorp Vault
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# Executor sandbox
EXECUTOR_SSH_USER=autopatch
EXECUTOR_CERT_TTL=5m

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=autopatch
MINIO_SECRET_KEY=autopatch_dev
MINIO_BUCKET=autopatch
MINIO_SECURE=false

# Notifications
NOTIFICATION_WEBHOOK_URL=

# Proxmox (for VM cloning)
PROXMOX_API_URL=https://10.100.201.24:8006
PROXMOX_API_TOKEN=terraform@pam!terraform=<your-token-uuid>
PROXMOX_NODE=pve
PROXMOX_TLS_INSECURE=true

# E2E testing
AUTOPATCH_E2E_OPENVAS=false
